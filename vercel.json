{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "web": {
      "entrypoint": ".",
      "framework": "nextjs",
      "routePrefix": "/"
    },
    "eve": {
      "buildCommand": "eve build",
      "entrypoint": ".",
      "framework": "eve",
      "routePrefix": "/_eve_internal/eve"
    }
  },
  "crons": [
    {
      "path": "/api/judge/batch",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/segment/batch",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/feedback-report",
      "schedule": "0 9 * * *"
    }
  ]
}
